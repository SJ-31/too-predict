alias mount_data="sshfs $stem_ip:/data/project/stemcell/shannc ~/Bio_SDD/too-predict/remote"
alias unmount_data="sudo umount -l ~/Bio_SDD/too-predict/remote"
alias venv="source ~/Bio_SDD/too-predict/.venv/bin/activate"
export CUDA_HOME="/data/home/shannc/lib/cuda"
export PATH="/data/home/shannc/lib/cuda"
export LD_LIBRARY_PATH="/data/project/stemcell/shannc/envs/too-predict/lib"

resetData() {
    sudo umount ~/Bio_SDD/too-predict/remote && sshfs $stem_ip:/data/project/stemcell/shannc ~/Bio_SDD/too-predict/remote
}
